# App
APP_ENV=dev
APP_LOG_LEVEL=INFO

# Storage
STORAGE_INPUT_DIR=./data/input
STORAGE_OUTPUT_DIR=./data/output

# Database
DB_DSN=sqlite:///./data/asr.db

# ASR
ASR_PROVIDER=whisper
ASR_MODEL=whisper-large-v3-turbo

# Emotion
EMOTION_PROVIDER=rubert
EMOTION_MODEL=cointegrated/rubert-tiny2

# Airflow
AIRFLOW_SCHEDULE=0 0 * * *
AIRFLOW_SLA_HOUR_MSK=8

# Online API
ONLINE_API_HOST=0.0.0.0
ONLINE_API_PORT=8080
