# App
APP_ENV=dev
APP_LOG_LEVEL=INFO

# Shared database
DB_DSN=sqlite:///./data/asr.db

# Batch storage and paths
BATCH_INPUT_DIR=./data/input
BATCH_OUTPUT_DIR=./data/output
BATCH_STORAGE_ACCESS_KEY=
BATCH_STORAGE_SECRET_KEY=

# Batch model providers
BATCH_ASR_PROVIDER=whisper
BATCH_ASR_MODEL=whisper-large-v3-turbo
BATCH_EMOTION_PROVIDER=rubert
BATCH_EMOTION_MODEL=cointegrated/rubert-tiny2

# Batch orchestration
BATCH_AIRFLOW_SCHEDULE=0 0 * * *
BATCH_AIRFLOW_SLA_HOUR_MSK=8

# Online service
ONLINE_API_HOST=0.0.0.0
ONLINE_API_PORT=8080
ONLINE_API_TOKEN=
